// TabCall — Prisma schema (v2.0 PRD §9 + Phase 2 menu/billing/tip extensions)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  STARTER
  FLAT
  FOUNDING
}

enum SubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PreOrderStatus {
  PENDING
  READY
  PICKED_UP
  CANCELED
}

enum TipPoolPeriod {
  SHIFT
  DAY
  WEEK
}

enum PosType {
  NONE
  TOAST
  SQUARE
  CLOVER
}

enum StaffRole {
  // Phase-1 RBAC. Roles are ordered loosely by privilege. Existing
  // legacy STAFF rows are migrated to OWNER (they were the venue
  // creator from /api/signup) — STAFF stays in the enum so the
  // migration is non-destructive but is no longer assigned.
  OWNER
  MANAGER
  SERVER
  HOST
  VIEWER
  STAFF // legacy — do not assign new rows
}

enum StaffStatus {
  ACTIVE
  INVITED // sent magic link, never signed in
  SUSPENDED // soft-disabled; row retained for audit history
}

enum RequestType {
  DRINK
  BILL
  HELP
  REFILL
}

enum RequestStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
  ESCALATED
}

// What the staff member actually did when resolving a request. Captured
// at the time of resolution so analytics can split "served on time" from
// "comped because we made them wait" from "couldn't help" etc. Required
// when transitioning a request to RESOLVED — the staff queue UI shows a
// small picker before flipping the status.
enum ResolutionAction {
  SERVED
  COMPED
  REFUSED
  ESCALATED
  NOT_ACTIONABLE
  OTHER
}

model Organization {
  id                    String             @id @default(cuid())
  name                  String
  plan                  Plan               @default(FOUNDING)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  // Stripe Billing snapshot — populated by customer.subscription.* webhooks.
  // Drives the "is the org current?" gate that hides paywalled features.
  subscriptionStatus    SubscriptionStatus @default(NONE)
  subscriptionPriceId   String?
  subscriptionPeriodEnd DateTime?
  trialEndsAt           DateTime?
  createdAt             DateTime           @default(now())
  venues                Venue[]
  members               OrgMember[]
}

model Venue {
  id                     String           @id @default(cuid())
  orgId                  String
  slug                   String           @unique
  name                   String
  address                String?
  zipCode                String?
  timezone               String           @default("America/Chicago")
  posType                PosType          @default(NONE)
  posWebhookUrl          String?
  googlePlaceId          String?
  stripeAccountId        String?
  // Stripe Connect onboarding state — populated by account.updated webhook.
  // chargesEnabled gates the bill flow; payoutsEnabled affects settlement.
  stripeChargesEnabled   Boolean          @default(false)
  stripePayoutsEnabled   Boolean          @default(false)
  stripeDetailsSubmitted Boolean          @default(false)
  // Compliance: when true, the first DRINK request on a fresh guest session
  // sets `idCheckRequired` on the request so staff see a coral "ID check"
  // badge before tapping Got it.
  requireIdOnFirstDrink  Boolean          @default(false)
  brandColor             String?
  logoUrl                String?
  // Tier 3a: optional grouping tag for hierarchical filtering in the
  // multi-location operator console (e.g. "Texas locations only").
  regionTag              String?
  // Comma-separated extra email recipients for bad-rating alerts and
  // similar venue-level notifications. Empty = use OPERATOR_EMAILS only.
  alertEmails            String?
  // Per-shift kill switches. Manager can flip these from Settings to
  // pause a feature (kitchen slammed, no servers on the floor, etc.)
  // without losing existing data. Default true so new venues "just work".
  requestsEnabled        Boolean          @default(true)
  preorderEnabled        Boolean          @default(true)
  reservationsEnabled    Boolean          @default(true)
  // Optional guest-facing copy. Manager-editable from Settings; the
  // guest flow falls back to baked-in defaults when these are null.
  // Keep concise — these render inline in the QR landing and feedback
  // screen, so long blocks of text would push the action buttons off
  // a phone viewport.
  guestWelcomeMessage    String?          @db.Text
  guestConfirmationMessage String?        @db.Text
  reviewPrompt           String?          @db.Text
  // Onboarding feature toggles. Persists the user's choices from Step 4
  // of the wizard. Null means defaults (everything on). JSON shape:
  //   { qr_ordering: bool, qr_payments: bool, call_waiter: bool,
  //     reviews: bool, pos_integration: bool }
  enabledFeatures        Json?
  createdAt              DateTime         @default(now())
  org                    Organization     @relation(fields: [orgId], references: [id])
  tables                 Table[]
  staff                  StaffMember[]
  sessions               GuestSession[]
  requests               Request[]
  feedback               FeedbackReport[]
  menuCategories         MenuCategory[]
  menuItems              MenuItem[]
  tipPools               TipPool[]
  preOrders              PreOrder[]
  reservations           Reservation[]
  waitlist               Waitlist[]
  specials               VenueSpecial[]
  auditLog               AuditLog[]
  // Spec-verbatim Guest Commerce Module (parallel schema; coexists with
  // PreOrder/VenueSpecial/legacy BillSplit). See migration
  // 20260512_guest_commerce_v2 for the trade-offs.
  orders                 Order[]
  bills                  Bill[]
  promotions             Promotion[]
  wishlists              Wishlist[]
  posSyncLogs            PosSyncLog[]
  venueBranding          VenueBranding?
  posIntegration         PosIntegration?

  @@index([orgId])
}

// Time-windowed promotions a venue surfaces to guests on the QR landing.
// "Happy hour", "$5 well drinks until 7", "tonight's wine flight", etc.
// Both window fields nullable so an "always-on" special is possible
// (e.g. signature cocktail, weekly recurring on the manager's end).
model VenueSpecial {
  id          String    @id @default(cuid())
  venueId     String
  title       String
  description String?
  // Optional headline price. Stored in cents so analytics can compute
  // discount-vs-rack later. Null = "see menu" or "ask staff".
  priceCents  Int?
  // Active window. Null/null = always shown when active.
  startsAt    DateTime?
  endsAt      DateTime?
  // Soft toggle so a manager can pull a special without deleting it.
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  venue       Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, active, startsAt])
  @@index([venueId, endsAt])
}

// Phase 2: menu management. Bills are still authored as JSON line items on
// GuestSession (kept for flexibility — comps, custom drinks, etc.) but the
// menu drives the staff "add to tab" picker and the guest browse/pre-order
// experience.
model MenuCategory {
  id        String     @id @default(cuid())
  venueId   String
  name      String
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  venue     Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  items     MenuItem[]

  @@index([venueId])
}

model MenuItem {
  id            String        @id @default(cuid())
  venueId       String
  categoryId    String?
  name          String
  description   String?
  priceCents    Int
  isActive      Boolean       @default(true)
  isFeatured    Boolean       @default(false)
  sortOrder     Int           @default(0)
  imageUrl      String?
  // Drinks/alcohol → trip the same first-drink ID-check flag a DRINK
  // request would. Lets a venue mark a soda as non-alcoholic so a refill
  // doesn't ask for ID.
  ageRestricted Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  venue         Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  category      MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems    OrderItem[]
  promotionLinks PromotionItem[]
  wishlistItems WishlistItem[]

  @@index([venueId, isActive])
  @@index([venueId, isFeatured])
  @@index([categoryId])
}

model Table {
  id          String            @id @default(cuid())
  venueId     String
  label       String
  qrToken     String            @unique
  zone        String?
  createdAt   DateTime          @default(now())
  venue       Venue             @relation(fields: [venueId], references: [id])
  sessions    GuestSession[]
  requests    Request[]
  assignments TableAssignment[]
  preOrders   PreOrder[]
  reservations Reservation[]
  // Guest Commerce Module back-refs.
  orders      Order[]
  bills       Bill[]
  wishlists   Wishlist[]

  @@unique([venueId, label])
  @@index([venueId])
}

model StaffMember {
  id            String            @id @default(cuid())
  venueId       String
  name          String
  email         String            @unique
  role          StaffRole         @default(SERVER)
  status        StaffStatus       @default(ACTIVE)
  fcmToken      String?
  createdAt     DateTime          @default(now())
  // Last successful sign-in via /api/auth/callback. Surfaces on the
  // People page so managers can spot stale accounts that should be
  // suspended.
  lastSeenAt    DateTime?
  // Lower bound on JWT iat that's considered valid. "Sign out everywhere"
  // bumps this to NOW(); any cached session JWT issued before this
  // timestamp gets rejected at verifySessionToken. Nullable: rows
  // pre-dating the feature retain unrestricted token TTL.
  sessionsValidAfter DateTime?
  // Free-text section assignment (e.g. "Patio", "Bar", "Floor 2"). Used
  // alongside TableAssignment for venues that group staff by zone rather
  // than per-table. Pure metadata — display + filter only.
  section            String?
  // Optional password sign-in. Magic-link remains the default path;
  // password is an opt-in upgrade. Nullable so every existing row
  // keeps working unchanged. passwordChangedAt mirrors the
  // sessionsValidAfter pattern — rotating the password invalidates
  // every JWT minted before the change.
  passwordHash      String?
  passwordChangedAt DateTime?
  // Stamped on first successful magic-link sign-in. Password sign-in
  // refuses to mint a session until this is set. Null means the user
  // signed up but never clicked their magic link.
  emailVerifiedAt   DateTime?
  // Self-referential audit: who invited this row, who suspended it.
  // Both nullable so the original venue OWNER (created by signup)
  // doesn't need a phantom inviter.
  invitedById   String?
  invitedBy     StaffMember?      @relation("StaffInvites", fields: [invitedById], references: [id])
  invitesSent   StaffMember[]     @relation("StaffInvites")
  suspendedAt   DateTime?
  suspendedById String?
  suspendedBy   StaffMember?      @relation("StaffSuspends", fields: [suspendedById], references: [id])
  suspended     StaffMember[]     @relation("StaffSuspends")

  venue         Venue             @relation(fields: [venueId], references: [id])
  ackedRequests Request[]         @relation("AcknowledgedBy")
  assignments   TableAssignment[]

  @@index([venueId])
  @@index([venueId, status])
}

// Append-only audit trail for sensitive admin actions. Today we emit
// on staff invites/role-changes/suspends/removals so a manager can
// reconstruct who promoted which bartender to manager three weeks
// ago. Other surfaces (menu, billing) can plug in later by calling
// the same `audit()` helper.
model AuditLog {
  id         String   @id @default(cuid())
  venueId    String
  venue      Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  // Who did it. We store the email at action-time rather than an FK
  // so the entry survives the actor being removed from the venue.
  actorEmail String
  actorRole  String
  // Dot-namespaced action verb, e.g. "staff.invited",
  // "staff.role_changed", "staff.suspended", "staff.removed".
  action     String
  targetType String?
  targetId   String?
  // Free-form structured context: { fromRole, toRole, email, ... }.
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([venueId, createdAt])
  @@index([venueId, action])
}

// Many-to-many: staff cover tables. A staff member can cover multiple
// tables; a table can be covered by multiple staff (e.g. bartender +
// floater both cover the bar). When a request lands on an assigned table,
// the realtime emit also fires to staff:{id} rooms for those staff.
model TableAssignment {
  tableId       String
  staffMemberId String
  createdAt     DateTime    @default(now())
  table         Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  staff         StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@id([tableId, staffMemberId])
  @@index([staffMemberId])
}

model GuestSession {
  id                    String           @id @default(cuid())
  venueId               String
  tableId               String
  sessionToken          String           @unique
  lineItems             Json             @default("[]")
  tipPercent            Float?
  paidAt                DateTime?
  stripePaymentIntentId String?
  // Tier 3c: optional link to a returning guest's profile. Set when the
  // guest identified via /api/v/[slug]/profile/identify before paying.
  guestProfileId        String?
  expiresAt             DateTime
  createdAt             DateTime         @default(now())
  venue                 Venue            @relation(fields: [venueId], references: [id])
  table                 Table            @relation(fields: [tableId], references: [id])
  requests              Request[]
  feedback              FeedbackReport[]
  splits                BillSplit[]
  preOrders             PreOrder[]
  guestProfile          GuestProfile?    @relation(fields: [guestProfileId], references: [id])
  // Guest Commerce Module back-refs (V2 schema).
  orders                Order[]
  billSplitsV2          BillSplitV2[]
  wishlist              Wishlist?

  @@index([venueId, tableId])
  @@index([expiresAt])
  @@index([guestProfileId])
}

// Bill split: a single GuestSession can be paid in N parts, each a separate
// Stripe PaymentIntent. The session is marked paidAt only when all splits
// have been paid (sum of split.paidCents >= bill total).
model BillSplit {
  id                    String       @id @default(cuid())
  sessionId             String
  // Optional human label ("Maya", "Tab 1", etc.) so guests at the same
  // table can tell which split is theirs.
  label                 String?
  amountCents           Int
  tipPercent            Float
  stripePaymentIntentId String?
  paidAt                DateTime?
  createdAt             DateTime     @default(now())
  session               GuestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([stripePaymentIntentId])
}

// Pre-order: guest browses menu via QR before/while seated, pays now,
// staff sees a "make these" card. Optional table — pre-orders without a
// table are pickup orders the guest grabs from the bar.
model PreOrder {
  id                    String         @id @default(cuid())
  venueId               String
  tableId               String?
  sessionId             String?
  status                PreOrderStatus @default(PENDING)
  items                 Json // [{ menuItemId, name, quantity, unitCents }]
  subtotalCents         Int
  tipCents              Int            @default(0)
  totalCents            Int
  stripePaymentIntentId String?
  paidAt                DateTime?
  guestName             String?
  guestPhone            String?
  pickupCode            String? // 4-digit short code shown on confirmation
  notes                 String?
  readyAt               DateTime?
  pickedUpAt            DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  venue                 Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  table                 Table?         @relation(fields: [tableId], references: [id], onDelete: SetNull)
  session               GuestSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([venueId, status])
  @@index([sessionId])
}

// Tip pooling: aggregate tips over a period and distribute across staff
// who worked. We do NOT touch funds — we record splits and the manager
// settles via cash/payroll. Stripe Connect doesn't support arbitrary
// venue → staff transfers without a marketplace marketplace setup.
model TipPool {
  id             String         @id @default(cuid())
  venueId        String
  period         TipPoolPeriod  @default(SHIFT)
  startedAt      DateTime
  endedAt        DateTime?
  // Total tips collected during this period (mirrored from GuestSession
  // tipPercent + payment data at close time).
  totalTipsCents Int            @default(0)
  closedAt       DateTime?
  createdAt      DateTime       @default(now())
  venue          Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  shares         TipPoolShare[]

  @@index([venueId, startedAt])
}

model TipPoolShare {
  id            String    @id @default(cuid())
  poolId        String
  staffMemberId String
  // Hours worked or weight assigned (e.g., bartender = 1.0, barback = 0.5).
  shareWeight   Float     @default(1.0)
  // Computed payout once the pool is closed.
  payoutCents   Int       @default(0)
  paidOutAt     DateTime?
  createdAt     DateTime  @default(now())
  pool          TipPool   @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([poolId, staffMemberId])
  @@index([staffMemberId])
}

model Request {
  id               String        @id @default(cuid())
  venueId          String
  tableId          String
  sessionId        String
  type             RequestType
  status           RequestStatus @default(PENDING)
  note             String?
  // For DRINK requests on a fresh session at compliance-flagged venues:
  // staff must acknowledge having checked ID before tapping Got it.
  idCheckRequired  Boolean       @default(false)
  acknowledgedById String?
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  // What the staff member actually did, captured at resolve-time. Null
  // for requests that were resolved by older versions of the app
  // before this column existed.
  resolutionAction ResolutionAction?
  resolutionNote   String?
  escalatedAt      DateTime?
  createdAt        DateTime      @default(now())
  venue            Venue         @relation(fields: [venueId], references: [id])
  table            Table         @relation(fields: [tableId], references: [id])
  session          GuestSession  @relation(fields: [sessionId], references: [id])
  acknowledgedBy   StaffMember?  @relation("AcknowledgedBy", fields: [acknowledgedById], references: [id])

  @@index([venueId, status])
  @@index([sessionId])
}

// Single-use enforcement for magic-link tokens. The link JWT carries a
// `jti` claim; the callback inserts the jti here on first redemption.
// On subsequent attempts the unique constraint blocks a fresh session.
// Rows older than 24h can be GC'd by a cron — token TTL is 15 minutes.
model LinkTokenUse {
  jti     String   @id
  staffId String
  usedAt  DateTime @default(now())

  @@index([usedAt])
}

// Single-use enforcement + audit log for "Comp this round" actions
// triggered from the AI bad-rating email. The email contains a signed
// JWT with a jti; applying the comp inserts the jti here so the link
// can't be replayed (e.g. forwarded to another manager).
model CompAction {
  jti         String   @id
  sessionId   String
  venueId     String
  amountCents Int
  reason      String?
  appliedAt   DateTime @default(now())

  @@index([sessionId])
  @@index([venueId, appliedAt])
}

// Stripe webhook idempotency: Stripe may deliver the same event multiple
// times. We insert by event ID; the unique constraint dedupes retries.
// `processedAt` lets us detect events that crashed mid-processing.
model WebhookEvent {
  id          String    @id // Stripe event ID, e.g. evt_1Abc...
  type        String
  payload     Json
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  error       String?

  @@index([type, receivedAt])
}

model FeedbackReport {
  id           String       @id @default(cuid())
  venueId      String
  // One feedback per session. The route already enforces this via a
  // findFirst+throw, but the unique constraint is the source of truth
  // and closes the concurrent-submit race window.
  sessionId    String       @unique
  rating       Int
  note         String?
  // AI classification (PRD v2.0 F4 — bad-review intercept)
  aiCategory   String? // service_speed | drink_quality | staff_attitude | wait_time | food | noise | other
  aiSuggestion String?
  aiServerName String?
  seenByMgr    Boolean      @default(false)
  // Manager-flagged for follow-up (escalation, refund, legal, etc).
  // Distinct from seenByMgr: a review can be seen AND flagged. Reviews
  // page filters on this column independently.
  flagged      Boolean      @default(false)
  flaggedAt    DateTime?
  createdAt    DateTime     @default(now())
  venue        Venue        @relation(fields: [venueId], references: [id])
  session      GuestSession @relation(fields: [sessionId], references: [id])

  @@index([venueId, createdAt])
}

// =====================================================================
// Tier 3 — Multi-location, reservations, loyalty, benchmarking
// =====================================================================

// --- Tier 3a: Multi-location operator console (OrgMember) ---

enum OrgMemberRole {
  OWNER
  ADMIN
  VIEWER
}

model OrgMember {
  id        String        @id @default(cuid())
  orgId     String
  email     String
  role      OrgMemberRole @default(VIEWER)
  createdAt DateTime      @default(now())
  org       Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([email])
}

// --- Tier 3b: Reservations + waitlist (Reservation, Waitlist, enums) ---

enum ReservationStatus {
  PENDING
  ARRIVED
  SEATED
  NO_SHOW
  CANCELED
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  SEATED
  ABANDONED
}

model Reservation {
  id         String            @id @default(cuid())
  venueId    String
  tableId    String?
  zone       String?
  partySize  Int
  startsAt   DateTime
  endsAt     DateTime
  guestName  String
  guestPhone String
  status     ReservationStatus @default(PENDING)
  notes      String?
  arrivedAt  DateTime?
  seatedAt   DateTime?
  // Short code the guest gets in their SMS — used to look up / cancel
  // their booking from the public page without exposing the row id.
  guestCode  String            @default(cuid())
  createdAt  DateTime          @default(now())
  venue      Venue             @relation(fields: [venueId], references: [id])
  table      Table?            @relation(fields: [tableId], references: [id])

  @@index([venueId, startsAt])
  @@index([guestPhone])
}

model Waitlist {
  id            String         @id @default(cuid())
  venueId       String
  partySize     Int
  guestName     String
  guestPhone    String
  quotedWaitMin Int
  joinedAt      DateTime       @default(now())
  notifiedAt    DateTime?
  seatedAt      DateTime?
  status        WaitlistStatus @default(WAITING)
  venue         Venue          @relation(fields: [venueId], references: [id])

  @@index([venueId, joinedAt])
}

// --- Tier 3c: Loyalty (GuestProfile + OTP) ---

model GuestProfile {
  id                     String         @id @default(cuid())
  phone                  String         @unique
  displayName            String?
  email                  String?        @unique
  // Per-venue points balance: { [venueId]: integer }. Mutated under
  // row-level lock during webhook processing so concurrent payments
  // don't race.
  loyaltyPointsByVenueId Json           @default("{}")
  preferences            Json           @default("{}")
  createdAt              DateTime       @default(now())
  sessions               GuestSession[]
  notes                  GuestNote[]
}

// Tier 3e: free-text notes pinned to a regular for staff handoff.
// Authored per-venue so a regular's note at Bar A doesn't leak to Bar B
// even if they have the same phone. Soft-delete via `deletedAt` so an
// accidental delete is recoverable.
model GuestNote {
  id              String       @id @default(cuid())
  guestProfileId  String
  venueId         String
  authorStaffId   String?
  authorName      String       // denormalized for display after staff churn
  body            String       @db.Text
  pinned          Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  guestProfile    GuestProfile @relation(fields: [guestProfileId], references: [id], onDelete: Cascade)

  @@index([guestProfileId, venueId])
  @@index([venueId, createdAt])
}

// 6-digit OTPs for phone-based guest identification. SHA-256 hashed so
// the table doesn't store plaintext codes. 5-minute TTL; max 5 attempts
// per row.
model GuestProfileOtp {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
}

// --- Tier 3d: Benchmarking (BenchmarkSnapshot) ---

model BenchmarkSnapshot {
  id          String   @id @default(cuid())
  date        DateTime
  // Stable hash of the segmentJson for unique-key purposes (Prisma
  // doesn't reliably support unique on Json). Compute via sha256 of
  // sorted-key stringified segmentJson.
  segmentKey  String
  segmentJson Json
  metric      String
  p25         Float
  p50         Float
  p75         Float
  p90         Float
  // K-anonymity guard: never expose values from segments where this is
  // below 5. The cron job refuses to write rows with sampleCount < 5.
  sampleCount Int
  createdAt   DateTime @default(now())

  @@unique([date, metric, segmentKey])
  @@index([date, metric])
}

// Cross-venue, platform-scoped audit log. Existing AuditLog requires a
// venueId; this table records actions that aren't bound to one venue
// (operator impersonation, org-level edits, broadcast emails, plan
// flips). Append-only. Backfill TODO: wire org-level operator routes
// to also emit here.
model OperatorAuditLog {
  id          String   @id @default(cuid())
  // Who did it — operator email at action time. Lookups by email
  // survive PlatformAdmin row deletion.
  actorEmail  String
  action      String   // dot-namespaced, e.g. "operator.impersonate.start"
  targetType  String?  // "Venue", "Organization", "StaffMember", ...
  targetId    String?
  // Free-form structured context: { venueSlug, asStaffEmail, reason, … }.
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([actorEmail, createdAt])
  @@index([action, createdAt])
}

// Platform-staff allowlist managed in-app. Two sources of truth for
// "is this user a TabCall founder?":
//   1. OPERATOR_EMAILS env (legacy, still respected — survives DB outage)
//   2. This table (managed via /operator/admins UI)
// `isPlatformStaffAsync()` checks both; `isPlatformStaff()` (sync) is
// env-only for tight render paths.
//
// Suspending an admin keeps the row for audit history; removing wipes
// it. Last-admin protection lives in the API route.
model PlatformAdmin {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  notes         String?
  // Password-based sign-in for the TabCall super-admin console.
  // Magic-link auth remains the only path for StaffMember rows;
  // password auth is platform-admin-only and gates /admin/login.
  passwordHash      String?
  passwordChangedAt DateTime?
  // Self-references for invite/suspend audit attribution.
  addedById     String?
  addedBy       PlatformAdmin? @relation("AdminAddedBy", fields: [addedById], references: [id])
  added         PlatformAdmin[] @relation("AdminAddedBy")
  suspendedAt   DateTime?
  suspendedById String?
  suspendedBy   PlatformAdmin? @relation("AdminSuspendedBy", fields: [suspendedById], references: [id])
  suspended     PlatformAdmin[] @relation("AdminSuspendedBy")
  lastSeenAt    DateTime?
  createdAt     DateTime       @default(now())

  @@index([email])
}

// =====================================================================
// Guest Commerce Module — spec-verbatim parallel schema
// =====================================================================
//
// These models coexist with the deployed flow (PreOrder, GuestSession,
// VenueSpecial, legacy BillSplit). The deployed `/v/[slug]/t/[tableId]/*`
// surface continues to use the original schema. The new `/guest/[qrToken]/*`
// surface uses these models. Either can be the source of truth on a
// per-venue basis; the admin screens will eventually surface both.
//
// Naming compromise: existing `BillSplit` keeps its name; the new
// item-level split model is `BillSplitV2` so Prisma doesn't collide.
// Schema migration would consolidate later; not in scope today.

enum OrderStatus {
  NEW
  ACCEPTED
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum OrderItemStatus {
  NEW
  ACCEPTED
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum BillStatus {
  OPEN
  PARTIAL
  PAID
  REFUNDED
  CANCELLED
}

enum BillItemStatus {
  UNPAID
  PAID
}

enum BillSplitV2Status {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PromotionType {
  HAPPY_HOUR
  BUSINESS_LUNCH
  BANNER
  LIMITED_TIME_ITEM
  NEW_ITEM
  DISCOUNT_HIGHLIGHT
}

enum PromotionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum WishlistStatus {
  ACTIVE
  CONVERTED
  CANCELLED
}

enum PosIntegrationStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  ERROR
}

model Order {
  id              String        @id @default(cuid())
  venueId         String
  tableId         String?
  guestSessionId  String?
  status          OrderStatus   @default(NEW)
  subtotalCents   Int
  taxCents        Int           @default(0)
  serviceCents    Int           @default(0)
  tipCents        Int           @default(0)
  totalCents      Int
  posReference    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  venue           Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  table           Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  guestSession    GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  bill            Bill?

  @@index([venueId, status, createdAt])
  @@index([guestSessionId])
}

model OrderItem {
  id            String          @id @default(cuid())
  orderId       String
  menuItemId    String?
  nameSnapshot  String
  priceCents    Int
  quantity      Int             @default(1)
  notes         String?
  status        OrderItemStatus @default(NEW)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem      MenuItem?       @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  billItem      BillItem?

  @@index([orderId])
}

model Bill {
  id              String     @id @default(cuid())
  venueId         String
  tableId         String?
  orderId         String?    @unique
  status          BillStatus @default(OPEN)
  subtotalCents   Int
  taxCents        Int        @default(0)
  serviceCents    Int        @default(0)
  tipTotalCents   Int        @default(0)
  totalCents      Int
  amountPaidCents Int        @default(0)
  amountDueCents  Int
  posReference    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  venue           Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  table           Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  order           Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  items           BillItem[]
  splits          BillSplitV2[]

  @@index([venueId, status, createdAt])
}

model BillItem {
  id              String         @id @default(cuid())
  billId          String
  orderItemId     String?        @unique
  nameSnapshot    String
  priceCents      Int
  quantity        Int
  status          BillItemStatus @default(UNPAID)
  paidBySplitId   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  bill            Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  orderItem       OrderItem?     @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  paidBySplit     BillSplitV2?   @relation("BillItemPaidBy", fields: [paidBySplitId], references: [id], onDelete: SetNull)
  splitItems      BillSplitItem[]

  @@index([billId, status])
}

// Item-level bill split — the spec's `bill_splits`. Coexists with the
// legacy `BillSplit` model (which does even-N session splits). The "V2"
// suffix is purely to avoid the Prisma model-name collision.
model BillSplitV2 {
  id                    String         @id @default(cuid())
  billId                String
  guestSessionId        String?
  status                BillSplitV2Status @default(PENDING)
  subtotalCents         Int
  taxCents              Int            @default(0)
  serviceCents          Int            @default(0)
  tipCents              Int            @default(0)
  totalCents            Int
  paymentReference      String?
  stripePaymentIntentId String?
  paidAt                DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  bill                  Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  guestSession          GuestSession?  @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  splitItems            BillSplitItem[]
  paidItems             BillItem[]     @relation("BillItemPaidBy")

  @@index([billId, status])
  @@index([stripePaymentIntentId])
}

model BillSplitItem {
  id          String      @id @default(cuid())
  billSplitId String
  billItemId  String
  amountCents Int
  createdAt   DateTime    @default(now())
  billSplit   BillSplitV2 @relation(fields: [billSplitId], references: [id], onDelete: Cascade)
  billItem    BillItem    @relation(fields: [billItemId], references: [id], onDelete: Cascade)

  @@unique([billSplitId, billItemId])
}

model Promotion {
  id              String          @id @default(cuid())
  venueId         String
  title           String
  description     String?
  type            PromotionType
  bannerImageUrl  String?
  startsAt        DateTime?
  endsAt          DateTime?
  status          PromotionStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  venue           Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  items           PromotionItem[]

  @@index([venueId, status, startsAt])
}

model PromotionItem {
  id          String    @id @default(cuid())
  promotionId String
  menuItemId  String
  createdAt   DateTime  @default(now())
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([promotionId, menuItemId])
  @@index([menuItemId])
}

model Wishlist {
  id             String         @id @default(cuid())
  venueId        String
  tableId        String?
  guestSessionId String         @unique
  status         WishlistStatus @default(ACTIVE)
  sharedWithStaffAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  venue          Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  table          Table?         @relation(fields: [tableId], references: [id], onDelete: SetNull)
  guestSession   GuestSession   @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  items          WishlistItem[]

  @@index([venueId, status])
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  menuItemId String
  quantity   Int      @default(1)
  notes      String?
  createdAt  DateTime @default(now())
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, menuItemId])
}

model VenueBranding {
  id              String   @id @default(cuid())
  venueId         String   @unique
  logoUrl         String?
  primaryColor    String?
  secondaryColor  String?
  accentColor     String?
  fontFamily      String?
  welcomeMessage  String?
  bannerImageUrl  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  venue           Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model PosIntegration {
  id                   String               @id @default(cuid())
  venueId              String               @unique
  // "NONE" | "TOAST" | "SQUARE" | "CLOVER". Kept loose-typed so adding a
  // provider doesn't require a Prisma migration.
  provider             String
  status               PosIntegrationStatus @default(PENDING)
  // Encrypted blob — never read by frontend. The lib/pos/* abstraction
  // is the only thing that decrypts at request time.
  encryptedCredentials String?              @db.Text
  lastSyncAt           DateTime?
  lastError            String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  venue                Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([provider, status])
}

model PosSyncLog {
  id                  String   @id @default(cuid())
  venueId             String
  provider            String
  // Dot-namespaced verb: "menu.sync", "order.send", "order.update_status",
  // "bill.fetch", "bill.mark_paid".
  action              String
  // "success" | "error"
  status              String
  // Never include credentials in these. The lib/pos/* helpers strip
  // anything matching /token|secret|password|apiKey|api_key/i before
  // writing.
  requestPayloadSafe  Json?
  responsePayloadSafe Json?
  errorMessage        String?
  createdAt           DateTime @default(now())
  venue               Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
}
