{
  "name": "tabcall-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/assert-dev-db.mjs && next dev",
    "build": "node scripts/prebuild-migrate.mjs && prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test": "bun test src/lib/__tests__",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "node scripts/assert-dev-db.mjs && prisma migrate dev",
    "db:deploy": "node scripts/assert-dev-db.mjs && prisma migrate deploy",
    "db:bootstrap": "node scripts/assert-dev-db.mjs && node scripts/bootstrap-dev-db.mjs",
    "db:seed": "node scripts/assert-dev-db.mjs && bun prisma/seed.ts",
    "db:studio": "node scripts/assert-dev-db.mjs && prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.52.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.3.1",
    "@upstash/redis": "^1.34.3",
    "bcryptjs": "^3.0.3",
    "firebase": "^10.13.2",
    "firebase-admin": "^12.7.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.10",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resend": "^4.0.1",
    "socket.io-client": "^4.8.1",
    "stripe": "^17.4.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.13",
    "@types/node": "20.16.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3"
  }
}
