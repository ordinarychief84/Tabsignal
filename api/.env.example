# TabSignal Fastify backend — local env. Copy to .env.

# Port the Fastify HTTP + Socket.io server listens on.
PORT=4000

# Comma-separated list of origins allowed to connect (CORS + Socket.io).
# Dev: http://localhost:3000   Prod: https://tabsignal.app
ALLOWED_ORIGINS=http://localhost:3000

# Shared secret. The Next.js app sets this same value and includes it in
# `x-internal-secret` when calling /internal/emit. Anything else is rejected.
INTERNAL_API_SECRET=change-me-to-a-long-random-string

# Optional: structured log level (info | debug | warn | error)
LOG_LEVEL=info
