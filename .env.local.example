# TabCall — local env. Copy to .env.local and fill.
# Never commit .env.local. .gitignore already excludes it.

# --- Database (Supabase Postgres) ---
DATABASE_URL=
DIRECT_URL=                       # Prisma migrate uses this; Supabase pooler URL on DATABASE_URL

# --- Auth (NextAuth) ---
NEXTAUTH_SECRET=                  # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# --- Stripe (Connect + Payment Element + Invoices) ---
STRIPE_SECRET_KEY=                # sk_test_... in dev, sk_live_... in prod
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=  # pk_test_... — exposed to browser, safe by design
STRIPE_WEBHOOK_SECRET=            # whsec_... — primary signing secret (live or test, single mode)
STRIPE_WEBHOOK_SECRET_TEST=       # whsec_... — optional second secret so the same handler verifies test+live deliveries
STRIPE_CONNECT_CLIENT_ID=         # ca_... for Standard onboarding (skip if using Express)
STRIPE_PRICE_GROWTH=              # price_... — Stripe Price ID for the Growth plan ($99/mo)
STRIPE_PRICE_PRO=                 # price_... — Stripe Price ID for the Pro plan ($299/mo)

# --- Anthropic (AI bad-review intercept, Haiku 4.5) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Firebase Cloud Messaging (staff PWA push) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=             # paste the literal \n-escaped key

# --- Resend (transactional email — bad-rating alert, owner notifications) ---
RESEND_API_KEY=
RESEND_FROM=alerts@tabcall.app    # adjust once domain DNS is verified

# --- Realtime backend (Fastify + Socket.io, lives in /api/) ---
FASTIFY_INTERNAL_URL=http://localhost:4000        # Next.js → Fastify (server side)
INTERNAL_API_SECRET=change-me                     # MUST match api/.env
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000      # browser → Fastify

# --- Upstash Redis (future: socket.io adapter, BullMQ jobs) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Twilio (Tier 3: reservations / waitlist / loyalty OTP) ---
TWILIO_ACCOUNT_SID=               # ACxxxx... — leave blank in dev to mock SMS
TWILIO_AUTH_TOKEN=                # 32-char auth token from Twilio console
TWILIO_FROM_NUMBER=               # +15551234567 — the verified Twilio number to send from

# --- Benchmarks cron (Tier 3: nightly aggregation) ---
BENCHMARK_CRON_SECRET=            # Bearer token Vercel Cron passes to /api/cron/benchmarks

# --- Supabase Storage (venue logo uploads, etc.) ---
# NEXT_PUBLIC_SUPABASE_URL is already set above. The service role key powers
# server-side writes — keep this server-only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=        # eyJ... — Supabase project settings → API → service_role key

# --- Google Places (look up googlePlaceId during venue setup) ---
GOOGLE_PLACES_API_KEY=

# --- App ---
APP_URL=http://localhost:3000
PUBLIC_QR_BASE_URL=http://localhost:3000   # production: https://tabcall.app
